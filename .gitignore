# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/.terraform.lock.hcl

# App runtime
app/server_config.json

# Node.js
node_modules/
app/packages/*/dist/
app/packages/lambda/*/dist/
app/**/*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude Code — developer-local tool permissions. The shared equivalent
# lives at .claude/settings.json (commit that instead if you want the
# allowlist shared across the team).
.claude/settings.local.json
.claude/worktrees/
.worktrees/

# Auto-generated at dev/build time — committed as null, real state must not
# be committed (contains AWS ARNs/account IDs).
app/packages/server/src/generated/tfstate.ts

.make
