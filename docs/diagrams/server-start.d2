shape: sequence_diagram

user: "User"
discord: "Discord"
ix: "interactions\nLambda"
fu: "followup\nLambda"
ecs: "ECS"
eb: "EventBridge"
ud: "update-dns\nLambda"
r53: "Route 53"
ddb: "DynamoDB"

user -> discord: "/server-start palworld"
discord -> ix: "POST FunctionURL (signed)"
ix -> ix: "Ed25519 verify + canRun()"
ix -> discord: "type:5 deferred ack (< 3s)"
ix -> fu: "async invoke (FollowupPayload)"
fu -> ecs: "RunTask palworld-server"
ecs -> fu: "taskArn"
fu -> ddb: "put PENDING#taskArn (TTL 15m)"
fu -> discord: "PATCH @original 'starting...'"
ecs -> eb: "Task State Change (RUNNING)"
eb -> ud: "event"
ud -> ecs: "DescribeTasks -> ENI -> public IP"
ud -> r53: "UPSERT A palworld.example.com"
ud -> ddb: "get + delete PENDING#taskArn"
ud -> discord: "PATCH @original 'running'"
user -> r53: "DNS lookup"
user -> ecs: "UDP 8211"
