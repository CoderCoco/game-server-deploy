{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@/*":    ["./src/*"],
      "@app/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
